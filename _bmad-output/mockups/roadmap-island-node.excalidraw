    {
      "id": "spatial_diagram",
      "type": "text",
      "x": 60,
      "y": 490,
      "width": 500,
      "height": 220,
      "text": "         ┌──────────────────────┐\n         │    Island Sprite       │  ← SpriteRenderer (Layer 6)\n         │    (2.6 × 2.6 units)   │     flipX per ShouldFlip()\n         │                        │\n         │   ┌──glow behind──┐    │  ← SpriteRenderer (Layer 6, order -1)\n         │   │  purple circle │    │     only for CURRENT level\n         │   └────────────────┘    │\n         └──────────┬─────────────┘\n                    │\n              ★ ★ ★               ← uGUI Images (WorldSpace Canvas)\n              ⭐⭐☆                  22×22px, 3px gap, ~8px above badge\n                    │\n             ┌──────┴──────┐\n             │   Badge     │      ← uGUI Image + TMP (WorldSpace Canvas)\n             │  56×56 circle│        overlaps island bottom by ~0.18 units\n             │   \"7\"       │\n             └─────────────┘",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "angle": 0,
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
